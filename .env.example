# TradingAgents Environment Variables
# Copy this file to .env and fill in your API keys

# LLM API Keys (at least one required for AI-powered features)
# Option 1: xAI (Grok) - preferred
XAI_API_KEY=your_xai_api_key_here

# Option 2: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic for certain features
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# X/Twitter Signal Posting (optional)
# Get keys from https://developer.x.com
X_CONSUMER_KEY=your_consumer_key_here
X_CONSUMER_SECRET=your_consumer_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
